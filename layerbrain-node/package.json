{
  "name": "layerbrain",
  "version": "0.0.3",
  "description": "The official TypeScript and JavaScript library for the Layerbrain API",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "api.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm test",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:resources": "node scripts/generate-resources.mjs",
    "generate:api-docs": "node scripts/generate-api-docs.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "layerbrain",
    "sdk",
    "api",
    "typescript",
    "javascript"
  ],
  "author": "Layerbrain",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/layerbrain/layerbrain.git",
    "directory": "layerbrain-node"
  },
  "bugs": {
    "url": "https://github.com/layerbrain/layerbrain/issues"
  },
  "homepage": "https://github.com/layerbrain/layerbrain/tree/main/layerbrain-node#readme",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/ws": "^8.5.14",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
